# Industrial AI Assistant - Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=Industrial AI Assistant
APP_VERSION=1.0.0
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Frontend
FRONTEND_URL=http://localhost:8501

# Database
DATABASE_URL=sqlite+aiosqlite:///./industrial_ai.db

# Qdrant Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=industrial_assistant
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3
RERANKER_ENABLED=true

# GroundX (PDF Search)
GROUNDX_API_KEY=your_api_key
GROUNDX_BUCKET_ID=your_bucket_id

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Whisper (Audio Transcription)
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_MODEL=base

# File Upload Limits
MAX_PDF_SIZE_MB=100
MAX_AUDIO_SIZE_MB=100
MAX_IMAGE_SIZE_MB=25

# Encryption - Generate with: python scripts/generate_secret_key.py
# IMPORTANT: Replace with a real Fernet key before first use
SECRET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Default Model Settings
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL_NAME=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
DEFAULT_THEME=light

# Logging
LOG_LEVEL=INFO
